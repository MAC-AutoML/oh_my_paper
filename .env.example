# Example secrets for local oh my paper runs.
# Copy to .env for local use. .env is gitignored.

# OpenAI-compatible model endpoint.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://automl.aiserverai.online/v1
OPENAI_MODEL=
OPENAI_REVIEWER_MODEL=

# Semantic Scholar Graph API key.
# Sent as the x-api-key request header when semantic_scholar.mode resolves to api_key.
s2_api_key=

# Optional Codex/GitHub integration keys.
CODEX_API_KEY=
GITHUB_TOKEN=
